{
  "name": "quick-translate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "wxt build --mode development",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vitest": "^4.1.9",
    "wxt": "^0.20.0"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@unocss/preset-rem-to-px": "^66.7.2",
    "vue": "^3.5.38"
  }
}
